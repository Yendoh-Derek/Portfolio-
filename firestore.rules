rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if the user is authenticated (signed in)
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the input data has the required fields and types for messages
    function isValidMessage() {
      let incoming = request.resource.data;
      return incoming.name is string &&
             incoming.name.size() > 0 &&
             incoming.email is string &&
             incoming.email.size() > 0 &&
             incoming.message is string &&
             incoming.message.size() > 0;
    }

    // --- Collection Rules ---

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects: Public Read, Admin Write
    match /projects/{projectID} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Experience: Public Read, Admin Write
    match /experience/{experienceID} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Skills: Public Read, Admin Write
    match /skills/{skillID} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Analytics: Public Read, Admin Write
    match /analytics/{docID} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Messages: Admin Read/Delete, Public Create (with validation)
    match /messages/{messageID} {
      allow read, delete: if isAuthenticated();
      allow create: if isValidMessage();
      allow update: if false; 
    }

    // Rate Limits: Admin only (Server handles rate limiting via firebase-admin)
    match /rate_limits/{ip} {
      allow read, write: if isAuthenticated();
    }
  }
}
